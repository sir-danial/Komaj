DJANGO_SETTINGS_MODULE=config.settings.dev
DEBUG=True
DJANGO_SECRET_KEY=change-me-in-prod
ALLOWED_HOSTS=*
# Unlike ALLOWED_HOSTS, values here MUST include the scheme (Django 4+),
# e.g. https://komaj.darkube.ir — omitting it fails the deploy system check.
CSRF_TRUSTED_ORIGINS=

# --- Database (Phase 1: SQLite) ---
SQLITE_PATH=/data/db.sqlite3
# Phase 2: switch to Postgres by setting DATABASE_URL
# DATABASE_URL=postgres://user:pass@host:5432/komaj

# --- Cache (Phase 1: DatabaseCache) ---
# Phase 2: switch to Redis by setting CACHE_URL
# CACHE_URL=rediscache://host:6379/1

# --- Media/Storage ---
USE_S3_STORAGE=False
ARVAN_S3_ENDPOINT=https://s3.ir-thr-at1.arvanstorage.ir
ARVAN_ACCESS_KEY=
ARVAN_SECRET_KEY=
ARVAN_BUCKET=

# --- Payment (Zibal — primary gateway) ---
# Merchant id from the Zibal panel (https://zibal.ir). Set this in production.
# Use the value `zibal` to test against Zibal's shared test merchant, which hits
# the real endpoints without a real gateway. Leave empty to use the mock gateway.
ZIBAL_MERCHANT=
# Domain registered with Zibal (no scheme) — shows Zibal's trust badge in the footer.
# Leave empty until the gateway is live; the badge claims Zibal handles our payments.
ZIBAL_TRUST_SITE=

# --- Payment (Zarinpal — fallback, only used when ZIBAL_MERCHANT is empty) ---
ZARINPAL_MERCHANT_ID=
ZARINPAL_SANDBOX=True

# Sweep for payments whose callback never arrived, every N minutes (in-process).
# Default 10. Set to 0 only if you run `manage.py reconcile_payments` from a real cron.
# PAYMENTS_RECONCILE_INTERVAL_MINUTES=10

# Allow the fake "mock" gateway (approves every payment). Defaults to DEBUG.
# MUST stay False/unset in production — with it off and no merchant id, payments fail closed.
# PAYMENTS_ALLOW_MOCK=False

# --- SMS (Kavenegar) ---
# When empty, OTP codes are printed to the server console (dev). Set to enable real SMS.
KAVENEGAR_API_KEY=
# KAVENEGAR_OTP_TEMPLATE=komaj-otp

# --- OTP (rate limiting) ---
# OTP_TTL=120
# OTP_RESEND_COOLDOWN=60
# OTP_MAX_SENDS_PER_HOUR=5
# OTP_MAX_ATTEMPTS=5

# --- Pricing ---
# VAT_RATE=0.09

# --- Monitoring ---
SENTRY_DSN=
