DJANGO_SETTINGS_MODULE=config.settings.dev
DEBUG=True
DJANGO_SECRET_KEY=change-me-in-prod
ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=

# --- Database (Phase 1: SQLite) ---
SQLITE_PATH=/data/db.sqlite3
# Phase 2: switch to Postgres by setting DATABASE_URL
# DATABASE_URL=postgres://user:pass@host:5432/komaj

# --- Cache (Phase 1: DatabaseCache) ---
# Phase 2: switch to Redis by setting CACHE_URL
# CACHE_URL=rediscache://host:6379/1

# --- Media/Storage ---
USE_S3_STORAGE=False
ARVAN_S3_ENDPOINT=https://s3.ir-thr-at1.arvanstorage.ir
ARVAN_ACCESS_KEY=
ARVAN_SECRET_KEY=
ARVAN_BUCKET=

# --- Payment (Zarinpal) ---
ZARINPAL_MERCHANT_ID=
ZARINPAL_SANDBOX=True

# --- SMS (Kavenegar) ---
KAVENEGAR_API_KEY=

# --- Monitoring ---
SENTRY_DSN=
